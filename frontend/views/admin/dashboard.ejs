async function saveSettings(){
  var r = await api('/admin-api/config');
  var configs = (r.data && Array.isArray(r.data)) ? r.data : [];
  for(var k = 0; k < configs.length; k++){
    var cfg = configs[k];
    var inp = document.getElementById('cfg-' + cfg.key);
    if(inp && inp.value !== cfg.value){
      // Use PUT /admin-api/config with { key, value } format per API docs
      await api('/admin-api/config', { method:'PUT', body: { key: cfg.key, value: inp.value } });
    }
  }
  alert('配置已保存');
  renderSettings();
}

