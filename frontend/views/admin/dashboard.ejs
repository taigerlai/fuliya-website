async function getMessages(){
  var d=await api('/admin-api/messages');
  var list=d.data&&d.data.list?d.data.list:[];
  var total=d.data?d.data.total:0;
  var unread=0;for(var i=0;i<list.length;i++)if(list[i].status===0)unread++;
  var h='<div class="flex items-center justify-between mb-6"><div><h1 class="text-lg font-bold">留言管理</h1><p class="text-sm text-gray-400">共 '+total+' 条，'+unread+' 条未处理</p></div>';
  h+='<button class="border border-gray-300 text-gray-600 px-4 py-2 rounded-lg text-sm">📥 导出</button></div>';
  h+='<div class="bg-white rounded-xl border overflow-hidden"><table class="tbl"><thead><tr><th>姓名</th><th>公司</th><th>邮箱</th><th>需求</th><th>状态</th><th>操作</th></tr></thead><tbody>';
  for(var i=0;i<list.length;i++){
    var m=list[i];
    h+='<tr><td class="font-medium">'+h(m.name)+'</td><td>'+h(m.company||'-')+'</td><td>'+h(m.email)+'</td>';
    h+='<td class="max-w-[200px] truncate text-sm">'+h((m.demand||'').slice(0,30))+'</td>';
    h+='<td><span class="bdg '+(m.status===0?'bdg-y':'bdg-g')+'">'+(m.status===0?'未处理':'已处理')+'</span></td>';
    h+='<td>'+(m.status===0?'<span class="text-[#2ab39f] text-sm cursor-pointer" onclick="markMsg('+m.id+')">标记已处理</span>':'<span class="text-gray-400 text-sm">已处理</span>')+'</td></tr>';
  }
  h+='</tbody></table></div>';
  $('pc').innerHTML=h;
}
async function markMsg(id){await api('/admin-api/messages/'+id,{method:'PUT'});getMessages()}

