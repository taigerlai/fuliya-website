function _g(db, field, fallback){
  if(!db) return fallback;
  if(field==='title_zh') return db.content_zh || fallback;
  if(field==='title_en') return db.content_en || fallback;
  if(field==='subtitle_zh') return db.image_alt_zh || fallback;
  if(field==='subtitle_en') return db.image_alt_en || fallback;
  if(field==='items'){
    try{ var parsed = JSON.parse(db.content_zh || '[]'); if(Array.isArray(parsed)) return parsed; }catch(e){}
    return fallback;
  }
  return db[field] || fallback;
}

async function _saveMod(pg, key, sid){
  var container = document.querySelector('[data-pg="'+pg+'"][data-key="'+key+'"]');
  if(!container) return;
  var fields = ['content_zh','content_en','image_url','image_alt_zh','image_alt_en','title_zh','title_en','subtitle_zh','subtitle_en'];
  var d = {}, hasData = false;
  fields.forEach(function(f){
    var el = container.querySelector('[data-field="'+f+'"]');
    if(el) { d[f] = el.value; hasData = true; }
  });
  // Special handling for advantages items
  if(key==='advantages'){
    var items = [];
    for(var i=0;i<4;i++){
      var t = container.querySelector('[data-field="item_title_'+i+'"]');
      var de = container.querySelector('[data-field="item_desc_'+i+'"]');
      if(t && de) items.push({title:t.value, desc:de.value});
    }
    d.content_zh = JSON.stringify(items);
    hasData = true;
  }
  if(!hasData){ alert('没有需要保存的修改'); return; }
  if(sid > 0){
    var r = await api('/admin-api/sections/'+sid, {method:'PUT', body:d});
    if(r.code===0) alert('保存成功'); else alert(r.msg||'保存失败');
  } else {
    alert('该板块暂未在数据库创建记录');
  }
}

async function _togVis(cb, pg, key, sid){
  if(sid > 0) await api('/admin-api/sections/'+sid, {method:'PUT', body:{status:cb.checked?1:0}});
}

