}
async function toolAction(action){
  if(action === 'clear-cache'){
    var r = await api('/admin-api/tools/clear-cache', { method:'POST' });
    alert(r.msg || '缓存已清除');
  } else if(action === 'sitemap'){
    alert('已开始生成 Sitemap（演示功能）');
  } else if(action === 'ping-google' || action === 'ping-bing'){
    alert('已通知 ' + (action==='ping-google'?'Google':'Bing') + '（演示功能）');
  } else if(action === 'robots'){
    alert('编辑 robots.txt（演示功能）');
  } else if(action === 'llms'){
    alert('编辑 llms.txt（演示功能）');
  } else if(action === 'db-backup'){
    var r = await api('/admin-api/tools/clear-cache', { method:'POST' });
    alert(r.msg || '数据库备份完成');
  } else if(action === 'db-restore'){
    alert('请选择备份文件（演示功能）');
  } else if(action === 'db-download'){
    alert('下载功能（演示功能）');
  } else if(action === 'clear-log'){
    var r = await api('/admin-api/tools/clear-cache', { method:'POST' });
    alert(r.msg || '日志已清理');
  } else if(action === 'export-log'){
    alert('导出日志（演示功能）');
  } else {
    alert(action + ' (演示功能)');
  }
}

