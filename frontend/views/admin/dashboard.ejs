function switchSettingsTab(e, tabName){
  var tabs = ['basic','contact','social','seo','copyright'];
  tabs.forEach(function(t){
    var btn = document.getElementById('set-tab-'+t);
    var panel = document.getElementById('set-panel-'+t);
    if(btn){ btn.className = 'py-4 hover:text-gray-700 whitespace-nowrap inactive-tab'; }
    if(panel) panel.classList.add('hidden');
  });
  var activeBtn = document.getElementById('set-tab-'+tabName);
  var activePanel = document.getElementById('set-panel-'+tabName);
  if(activeBtn){ activeBtn.className = 'tab-active py-4 border-b-2 border-[#2ab39f] text-[#2ab39f] whitespace-nowrap'; }
  if(activePanel) activePanel.classList.remove('hidden');
  settingsCurrentTab = tabName;
}

