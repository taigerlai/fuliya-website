var currentPageSections = [];

async function loadSections(pageKey){
  var r = await api('/admin-api/sections?page=' + pageKey);
  currentPageSections = r.data || [];
  var container = document.getElementById('section-list-container');
  if(!container) return;
  var s = currentPageSections;
  if(!s.length){
    container.innerHTML = '<div class="p-8 text-center text-gray-400 text-sm">该页面暂无模块数据，请在数据库中录入 page_sections 记录。</div>';
    return;
  }
  var h = '';
  for(var i = 0; i < s.length; i++){
    var sec = s[i];
    var enabled = sec.status !== 0;
    var label = sec.name || sec.module_key || '未命名模块';
    var contentVal = sec.content_zh || sec.content || '';
    contentVal = contentVal.replace(/"/g, '&quot;');
    h += '<div class="p-4 lg:p-6 flex items-start gap-4 hover:bg-gray-50 transition group">' +
      '<div class="text-gray-300 cursor-move group-hover:text-gray-500 mt-1">&#9776;</div>' +
      '<div class="flex-1"><div class="flex items-center justify-between mb-2">' +
      '<h4 class="font-semibold text-gray-900 text-sm">模块' + (i+1) + '：' + label + '</h4>' +
      '<span class="text-xs ' + (enabled ? 'bg-green-100 text-green-600' : 'bg-gray-100 text-gray-600') + ' rounded-full px-2 py-0.5">' + (enabled ? '已启用' : '已禁用') + '</span></div>' +
      '<textarea rows="2" class="w-full px-3 py-2 border border-gray-200 rounded-lg text-xs font-mono text-gray-600" id="sec-content-' + sec.id + '">' + contentVal + '</textarea>' +
      '<div class="flex gap-2 mt-2">' +
      '<button class="text-[#2ab39f] text-xs hover:underline" onclick="alert(\'编辑HTML器(演示)\')">编辑HTML</button>' +
      '<button class="text-red-500 text-xs hover:underline" onclick="toggleSection(' + sec.id + ',' + (enabled ? 0 : 1) + ')">' + (enabled ? '禁用' : '启用') + '</button></div></div></div>';
  }
  container.innerHTML = h;
}

async function toggleSection(id, status){
  await api('/admin-api/sections/'+id, { method:'PUT', body:{ status: status } });
  var sel = document.getElementById('page-selector');
  loadSections(sel ? sel.value : 'home');
}

async function saveAllSections(){
  for(var k = 0; k < currentPageSections.length; k++){
    var sec = currentPageSections[k];
    var ta = document.getElementById('sec-content-' + sec.id);
    if(ta && ta.value !== (sec.content_zh || sec.content || '')){
      await api('/admin-api/sections/'+sec.id, { method:'PUT', body:{ content_zh: ta.value } });
    }
  }
  alert('全部模块已保存');
  var sel = document.getElementById('page-selector');
  if(sel) loadSections(sel.value);
}

