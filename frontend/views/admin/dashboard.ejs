<div class="flex" style="min-height:100vh">
<div class="w-60 bg-[#0f172a] fixed h-full" style="z-index:50">
<div class="p-5 border-b border-slate-800"><div class="text-white font-bold">富丽雅管理</div><div class="text-xs text-slate-500 mt-1">Admin Panel</div></div>
<div id="nav" class="py-3"></div></div>
<div class="flex-1 ml-60">
<div class="bg-white border-b h-16 flex items-center justify-between px-6 sticky top-0 z-40">
<span class="text-sm text-gray-400">当前：<span id="pt" class="font-semibold text-gray-800">...</span></span>
<div><span id="ai" class="text-sm text-gray-600 mr-3"></span><button id="lo" class="text-sm text-red-500 hover:underline">退出</button></div></div>
<div class="p-6" id="pc"><div class="text-center py-20 text-gray-400">⏳ 加载中...</div></div></div></div>
<div id="modal" class="mo" style="display:none" onclick="if(event.target===this)cm()"><div class="mb" id="mbd"></div></div>
<script>
var TK=localStorage.getItem('admin_token');
if(!TK){location.href='/admin'}
document.getElementById('lo').onclick=function(){localStorage.removeItem('admin_token');localStorage.removeItem('admin_nickname');location.href='/admin'};
document.getElementById('ai').textContent='\uD83D\uDC64 '+(localStorage.getItem('admin_nickname')||'管理员');
function $(id){return document.getElementById(id)}
function h(t){return String(t||'').replace(/</g,'&lt;').replace(/>/g,'&gt;')}
function om(h){$('modal').style.display='flex';$('mbd').innerHTML=h}
function cm(){$('modal').style.display='none'}

async function api(url,opts){
  if(!opts)opts={};
  if(!opts.headers)opts.headers={};
  opts.headers['Authorization']='Bearer '+TK;
  if(opts.body && typeof opts.body==='object'){
    opts.body=JSON.stringify(opts.body);
    opts.headers['Content-Type']='application/json';
  }
  try{
    var controller=new AbortController();
    var timer=setTimeout(function(){controller.abort()},10000);
    opts.signal=controller.signal;
    var r=await fetch(url,opts);
    clearTimeout(timer);
    var j=await r.json();
    if(j.code===-1 && j.msg && j.msg.indexOf('未')>=0){
      localStorage.removeItem('admin_token');
      location.href='/admin';
    }
    return j;
  }catch(e){
    return{code:-1,msg:e.message,data:null};
  }
}

var P=['dashboard','products','news','cases','pages','settings','messages','tools'];
var PT={'dashboard':'数据仪表盘','products':'产品管理','news':'新闻管理','cases':'案例管理','pages':'页面模块编辑','settings':'全站配置','messages':'留言管理','tools':'系统工具'};
var IC={'dashboard':'📊','products':'📦','news':'📰','cases':'📋','pages':'🏗️','settings':'⚙️','messages':'💬','tools':'🔧'};
var nav=$('nav');
P.forEach(function(p,i){
  var a=document.createElement('div');
  a.className='sd'+(i===0?' a':'');
  a.textContent=IC[p]+' '+PT[p];
  (function(pg){a.onclick=function(){sw(pg)}})(p);
  nav.appendChild(a);
});

function sw(p){
  var all=document.querySelectorAll('.sd');
  for(var i=0;i<all.length;i++)all[i].className='sd';
  nav.children[P.indexOf(p)].className='sd a';
  $('pt').textContent=PT[p];
  $('pc').innerHTML='<div class="text-center py-20 text-gray-400">⏳ 加载中...</div>';
  if(p==='dashboard')getDashboard();
  else if(p==='products')getProducts();
  else if(p==='news')getNews();
  else if(p==='cases')getCases();
  else if(p==='pages')showPages();
  else if(p==='settings')showSettings();
  else if(p==='messages')getMessages();
  else if(p==='tools')showTools();
}

async function getDashboard(){
  var d=await api('/admin-api/dashboard');
  if(!d.data){ $('pc').innerHTML='<div class="text-center py-10 text-gray-400">⚠️ 数据加载失败，请重试</div>'; return; }
  var s=d.data;
  var h='<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-8">';
  h+=card('产品总数',s.products);
  h+=card('新闻动态',s.news);
  h+=card('客户案例',s.cases);
  h+='</div><div class="bg-white rounded-xl border p-6"><h2 class="font-semibold mb-4">快捷操作</h2><div class="grid grid-cols-2 md:grid-cols-4 gap-3">';
  h+=btn('＋ 新增产品',"location.href='/admin/products/new'",'#e6f7f4');
  h+=btn('📰 发布新闻',"sw('news')",'#dbeafe');
  h+=btn('📋 查看留言',"sw('messages')",'#fef3c7');
  h+=btn('⚙️ 系统设置',"sw('settings')",'#f3f4f6');
  h+='</div></div>';
  $('pc').innerHTML=h;
}
function card(t,v,color){
  return '<div class="bg-white rounded-xl border p-6"><div class="text-sm text-gray-500 mb-1">'+t+'</div><div class="text-3xl font-bold '+(color||'')+'">'+v+'</div></div>';
}
function btn(t,o,bg){
  return '<div class="p-3 rounded-lg text-sm text-center cursor-pointer" style="background:'+bg+'" onclick="'+o+'">'+t+'</div>';
}

// Products
async function getProducts(){
  var d=await api('/admin-api/products');
  var list=d.data&&d.data.list?d.data.list:[];
  var total=d.data?d.data.total:0;
  var h='<div class="flex items-center justify-between mb-6"><div><h1 class="text-lg font-bold">产品管理</h1><p class="text-sm text-gray-400">共 '+total+' 款产品</p></div>';
  h+='<div class="flex gap-2"><button onclick="location.href=\'/admin/products/new\'" class="bg-[#2ab39f] text-white px-4 py-2 rounded-lg text-sm font-medium">＋ 新增产品</button>';
  h+='<button class="border border-gray-300 text-gray-600 px-4 py-2 rounded-lg text-sm">📤 导出</button></div></div>';
  h+='<div class="bg-white rounded-xl border overflow-hidden"><table class="tbl"><thead><tr><th>产品名称</th><th>分类</th><th>MOQ</th><th>状态</th><th>操作</th></tr></thead><tbody>';
  for(var i=0;i<list.length;i++){
    var p=list[i];
    h+='<tr><td class="font-medium">'+h(p.title_zh)+'</td><td>'+h(p.cat||'-')+'</td><td>'+h(p.moq||'-')+'</td>';
    h+='<td><span class="bdg '+(p.status===1?'bdg-g':'bdg-gy')+'">'+(p.status===1?'上架':'下架')+'</span></td>';
    h+='<td><a href="/admin/products/edit/'+p.id+'" class="text-[#2ab39f] text-sm cursor-pointer hover:underline">编辑</a><span class="text-gray-300 mx-1">|</span><span class="text-red-500 text-sm cursor-pointer" onclick="toggleProduct('+p.id+','+(p.status===1?0:1)+')">'+(p.status===1?'下架':'上架')+'</span></td></tr>';
  }
  h+='</tbody></table></div>';
  $('pc').innerHTML=h;
}
async function toggleProduct(id,st){await api('/admin-api/products/'+id,{method:'PUT',body:{status:st}});getProducts()}

// News
async function getNews(){
  var d=await api('/admin-api/news');
  var list=d.data&&d.data.list?d.data.list:[];
  var h='<div class="flex items-center justify-between mb-6"><div><h1 class="text-lg font-bold">新闻管理</h1><p class="text-sm text-gray-400">共 '+(d.data&&d.data.total||0)+' 篇</p></div>';
  h+='<button onclick="modalAddNews()" class="bg-[#2ab39f] text-white px-4 py-2 rounded-lg text-sm font-medium">＋ 发布新闻</button></div>';
  h+='<div class="bg-white rounded-xl border overflow-hidden"><table class="tbl"><thead><tr><th>标题</th><th>状态</th><th>操作</th></tr></thead><tbody>';
  for(var i=0;i<list.length;i++){
    var n=list[i];
    h+='<tr><td class="font-medium">'+h(n.title_zh)+'</td>';
    h+='<td><span class="bdg '+(n.status===1?'bdg-g':'bdg-gy')+'">'+(n.status===1?'已发布':'下架')+'</span></td>';
    h+='<td><span class="text-[#2ab39f] text-sm cursor-pointer">编辑</span><span class="text-gray-300 mx-1">|</span><span class="text-red-500 text-sm cursor-pointer" onclick="toggleNews('+n.id+','+(n.status===1?0:1)+')">'+(n.status===1?'下架':'发布')+'</span></td></tr>';
  }
  h+='</tbody></table></div>';
  $('pc').innerHTML=h;
}
async function toggleNews(id,st){await api('/admin-api/news/'+id,{method:'PUT',body:{status:st}});getNews()}

function modalAddNews(){
  om('<h2 class="text-lg font-bold mb-4">发布新闻</h2><form onsubmit="return submitNews(event)" class="space-y-4">'+
    '<div class="grid grid-cols-2 gap-4"><div><label class="text-sm font-semibold block mb-1">标题（中文）<span class="text-red-500">*</span></label><input class="fi" name="title_zh" required></div>'+
    '<div><label class="text-sm font-semibold block mb-1">标题（英文）</label><input class="fi" name="title_en"></div></div>'+
    '<div class="grid grid-cols-2 gap-4"><div><label class="text-sm font-semibold block mb-1">正文（中文）</label><textarea class="fi" name="content_zh" rows="4"></textarea></div>'+
    '<div><label class="text-sm font-semibold block mb-1">正文（英文）</label><textarea class="fi" name="content_en" rows="4"></textarea></div></div>'+
    '<div><label class="text-sm font-semibold block mb-1">标签</label><input class="fi" name="tags" placeholder="如: 公司新闻"></div>'+
    '<div class="flex gap-3"><button type="submit" class="bg-[#2ab39f] text-white px-6 py-2.5 rounded-lg text-sm">发布</button>'+
    '<button type="button" onclick="cm()" class="border border-gray-300 text-gray-600 px-6 py-2.5 rounded-lg text-sm">取消</button></div></form>');
}
async function submitNews(e){e.preventDefault();var f=new FormData(e.target);var d={};f.forEach(function(v,k){d[k]=v});await api('/admin-api/news',{method:'POST',body:d});cm();getNews();return false}

// Cases
async function getCases(){
  var d=await api('/admin-api/cases');
  var list=d.data&&d.data.list?d.data.list:[];
  var h='<div class="flex items-center justify-between mb-6"><div><h1 class="text-lg font-bold">案例管理</h1><p class="text-sm text-gray-400">共 '+(d.data&&d.data.total||0)+' 个</p></div>';
  h+='<button onclick="modalAddCase()" class="bg-[#2ab39f] text-white px-4 py-2 rounded-lg text-sm font-medium">＋ 新增案例</button></div>';
  h+='<div class="bg-white rounded-xl border overflow-hidden"><table class="tbl"><thead><tr><th>案例名称</th><th>客户</th><th>状态</th><th>操作</th></tr></thead><tbody>';
  for(var i=0;i<list.length;i++){
    var c=list[i];
    h+='<tr><td class="font-medium">'+h(c.title_zh)+'</td><td>'+h(c.client_name)+'</td>';
    h+='<td><span class="bdg '+(c.status===1?'bdg-g':'bdg-gy')+'">'+(c.status===1?'展示中':'已下架')+'</span></td>';
    h+='<td><span class="text-[#2ab39f] text-sm cursor-pointer">编辑</span><span class="text-gray-300 mx-1">|</span><span class="text-red-500 text-sm cursor-pointer" onclick="toggleCase('+c.id+','+(c.status===1?0:1)+')">'+(c.status===1?'下架':'展示')+'</span></td></tr>';
  }
  h+='</tbody></table></div>';
  $('pc').innerHTML=h;
}
async function toggleCase(id,st){await api('/admin-api/cases/'+id,{method:'PUT',body:{status:st}});getCases()}

function modalAddCase(){
