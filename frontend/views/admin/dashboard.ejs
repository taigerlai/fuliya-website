var _pageLabels = {home:'首页',products:'产品中心',about:'关于我们',strength:'企业实力',cases:'客户案例',news:'新闻博客',contact:'联系我们'};
var _pageKeys = ['home','products','about','strength','cases','news','contact'];

function showPages(){ _showPageMods('home'); }

async function _showPageMods(pg){
  var h='<div class="mb-4"><h1 class="text-lg font-bold">页面模块编辑</h1><p class="page-desc">选择页面，编辑模块内容</p></div>';
  h+='<div class="flex gap-2 mb-6 flex-wrap">';
  for(var i=0;i<_pageKeys.length;i++){
    h+='<span class="px-4 py-2 rounded-lg text-sm cursor-pointer '+(pg===_pageKeys[i]?'bg-[#2ab39f] text-white':'border border-gray-200 text-gray-600 hover:border-[#2ab39f]')+'" onclick="_showPageMods(\''+_pageKeys[i]+'\')">'+_pageLabels[_pageKeys[i]]+'</span>';
  }
  h+='</div><div id="page-sections-list" class="space-y-4"><div class="text-center py-10 text-gray-400">⏳ 加载板块...</div></div>';
  $('pc').innerHTML=h;
  await _renderModules(pg);
}

async function _renderModules(pg){
  var container = document.getElementById('page-sections-list');
  if(!container) return;
  var defs = _pageSectionDefs[pg] || [];
  if(!defs.length){ container.innerHTML='<div class="text-center py-10 text-gray-400">暂无可编辑的板块</div>'; return; }

  // Fetch DB data with timeout fallback
  var d = await Promise.race([
    api('/admin-api/sections?page='+pg),
    new Promise(function(resolve){
      setTimeout(function(){ resolve({code:-1,msg:'timeout',data:[]}); }, 6000);
    })
  ]);
  var dbData = d.data || [];
  function findByKey(k){ for(var i=0;i<dbData.length;i++){ if(dbData[i].section_key===k) return dbData[i]; } return null; }

  var h = '';
  for(var i=0;i<defs.length;i++){
    var def = defs[i];
    var db = findByKey(def.key);
    var st = db ? (db.status!==0) : true;
    var sid = db ? db.id : 0;

    h+='<div class="bg-white rounded-xl border border-gray-200 p-5" data-pg="'+pg+'" data-key="'+def.key+'" data-id="'+sid+'">';
    h+='  <div class="flex items-center justify-between mb-4">';
    h+='    <div><h3 class="font-semibold">'+def.idx+' '+def.title+'</h3><span class="text-xs text-gray-400">'+def.hint+'</span></div>';
    h+='    <div class="flex items-center gap-3">';
    h+='      <span class="text-xs '+(st?'text-green-600 bg-green-50':'text-gray-400 bg-gray-100')+' px-2 py-0.5 rounded">'+(st?'显示中':'已隐藏')+'</span>';
    h+='      <label class="relative inline-flex items-center cursor-pointer">';
    h+='        <input type="checkbox" class="sr-only peer" '+(st?'checked':'')+' onchange="_togVis(this,\''+pg+'\',\''+def.key+'\','+sid+')">';
