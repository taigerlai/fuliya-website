// === BATCH ACTIONS (real API calls) ===
function batchAction(type, action) {
  var pageContent = document.getElementById('pageContent');
  var checkboxes = pageContent.querySelectorAll('input[type="checkbox"]:checked');
  var ids = [];
  checkboxes.forEach(function(cb){
    var row = cb.closest('tr');
    if(row){
      var cells = row.querySelectorAll('td');
      if(cells.length >= 2){
        var txt = cells[1].textContent.trim();
        var num = parseInt(txt.replace(/[^0-9]/g, ''));
        if(!isNaN(num)) ids.push(num);
      }
    }
  });
  if(ids.length === 0){ alert('请先勾选要操作的项目'); return; }
  if(!confirm('确认对 ' + ids.length + ' 条记录执行操作?')) return;

  if(type === 'products'){
    if(action === 'delete'){
      ids.forEach(function(id){ api('/admin-api/products/'+id, { method:'DELETE' }); });
      setTimeout(function(){ switchPage('products'); }, 500);
    } else if(action === 'publish'){
      ids.forEach(function(id){ api('/admin-api/products/'+id, { method:'PUT', body: { status: 1 } }); });
      setTimeout(function(){ switchPage('products'); }, 500);
    }
  } else if(type === 'messages'){
    if(action === 'read'){
      ids.forEach(function(id){ api('/admin-api/messages/'+id, { method:'PUT', body: { status: 1 } }); });
      setTimeout(function(){ switchPage('messages'); }, 500);
    } else if(action === 'unread'){
      ids.forEach(function(id){ api('/admin-api/messages/'+id, { method:'PUT', body: { status: 0 } }); });
      setTimeout(function(){ switchPage('messages'); }, 500);
    } else if(action === 'delete'){
      ids.forEach(function(id){ api('/admin-api/messages/'+id, { method:'DELETE' }); });
      setTimeout(function(){ switchPage('messages'); }, 500);
    } else if(action === 'export'){
      alert('导出CSV(演示)');
    }
  }
}

function switchProdTab(e, tab) {
  var tabs = ['basic','seo','params','detail','faq','related','preview'];
  tabs.forEach(function(t){
    var btn = document.getElementById('prod-tab-' + t);
    var panel = document.getElementById('prod-panel-' + t);
    if (btn) { btn.className = 'py-4 hover:text-gray-700 whitespace-nowrap inactive-tab'; }
    if (panel) panel.classList.add('hidden');
  });
  var activeBtn = document.getElementById('prod-tab-' + tab);
  var activePanel = document.getElementById('prod-panel-' + tab);
  if (activeBtn) { activeBtn.className = 'tab-active py-4 border-b-2 border-[#2ab39f] text-[#2ab39f] whitespace-nowrap'; }
  if (activePanel) activePanel.classList.remove('hidden');
}

