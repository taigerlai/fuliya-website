<!DOCTYPE html>
<html lang="zh-CN"><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1.0"><title>管理后台 - 富丽雅</title><script src="https://cdn.tailwindcss.com"></script><script>tailwind.config={theme:{extend:{colors:{brand:{DEFAULT:'#2ab39f',light:'#3dcfba',dark:'#1f8f7e',lighter:'#e8f8f5'}},fontFamily:{sans:['Inter','"Noto Sans SC"','sans-serif']}}}</script><style>body{font-family:'Inter','Noto Sans SC',sans-serif;}.active-page{background:rgba(42,179,159,.2)!important;color:#2ab39f!important;font-weight:500!important}.section-title{font-size:1.25rem;font-weight:700;margin-bottom:1rem}.admin-table{width:100%;border-collapse:collapse}.admin-table th{text-align:left;padding:.75rem 1rem;font-size:.8125rem;font-weight:600;color:#64748b;background:#f8fafc;border-bottom:2px solid #e5e7eb}.admin-table td{padding:.75rem 1rem;font-size:.875rem;border-bottom:1px solid #f1f5f9;color:#334155}.admin-table tr:hover td{background:#f8fafc}.badge{padding:.1875rem .625rem;border-radius:9999px;font-size:.75rem;font-weight:500}.badge-green{background:#dcfce7;color:#15803d}.badge-yellow{background:#fef9c3;color:#a16207}.badge-gray{background:#f1f5f9;color:#64748b}.badge-brand{background:#e8f8f5;color:#2ab39f}.badge-blue{background:#eff6ff;color:#2563ed}.badge-purple{background:#f5f3ff;color:#9333ea}.badge-amber{background:#fffbeb;color:#d97706}.badge-rose{background:#fff1f2;color:#e11d48}.form-input{width:100%;padding:.625rem .875rem;border:1px solid #d1d5db;border-radius:.5rem;font-size:.875rem;outline:none;transition:all .2s}.form-input:focus{border-color:#2ab39f;box-shadow:0 0 0 3px rgba(42,179,159,.15)}.form-label{display:block;font-size:.8125rem;font-weight:600;color:#374151;margin-bottom:.375rem}.stat-card{background:#fff;border-radius:.75rem;padding:1.5rem;border:1px solid #e5e7eb}.stat-card:hover{border-color:#2ab39f}.hidden{display:none!important}.active-tab{color:#2ab39f!important;border-bottom:2px solid #2ab39f!important}.inactive-tab{color:#6b7280!important;border-bottom:2px solid transparent!important}.tab-active{border-bottom:2px solid #2ab39f;color:#2ab39f}</style></head><body>
<div id="app" class="flex min-h-screen bg-gray-50">
<aside class="w-60 bg-gray-900 flex-shrink-0 min-h-screen hidden lg:flex flex-col">
<div class="h-16 flex items-center gap-2 px-5 border-b border-gray-800"><div class="w-9 h-9 bg-[#2ab39f] rounded-lg flex items-center justify-center text-white font-bold text-sm">富</div><span class="font-bold text-white text-sm">富丽雅管理后台</span></div>
<nav class="flex-1 py-4 px-3 space-y-1 text-sm" id="adminNav">
<svg style="display:none"><symbol id="icon-dashboard" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg><symbol id="icon-products" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg><symbol id="icon-news" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg><symbol id="icon-cases" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg><symbol id="icon-pages" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 5a1 1 0 011-1h14a1 1 0 011 1v2a1 1 0 01-1 1H5a1 1 0 01-1-1V5zM4 13a1 1 0 011-1h6a1 1 0 011 1v6a1 1 0 01-1 1H5a1 1 0 01-1-1v-6zM16 13a1 1 0 011-1h2a1 1 0 011 1v6a1 1 0 01-1 1h-2a1 1 0 01-1-1v-6z"/></svg><symbol id="icon-settings" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg><symbol id="icon-messages" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/></svg><symbol id="icon-tools" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/></svg></svg>
<a class="flex items-center gap-3 px-3 py-2.5 text-gray-400 cursor-pointer hover:bg-gray-800 hover:text-white rounded-lg transition" data-page="dashboard"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><use href="#icon-dashboard"/></svg>数据仪表盘</a>
<a class="flex items-center gap-3 px-3 py-2.5 text-gray-400 cursor-pointer hover:bg-gray-800 hover:text-white rounded-lg transition" data-page="products"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><use href="#icon-products"/></svg>产品管理</a>
<a class="flex items-center gap-3 px-3 py-2.5 text-gray-400 cursor-pointer hover:bg-gray-800 hover:text-white rounded-lg transition" data-page="news"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><use href="#icon-news"/></svg>新闻管理</a>
<a class="flex items-center gap-3 px-3 py-2.5 text-gray-400 cursor-pointer hover:bg-gray-800 hover:text-white rounded-lg transition" data-page="cases"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><use href="#icon-cases"/></svg>案例管理</a>
<a class="flex items-center gap-3 px-3 py-2.5 text-gray-400 cursor-pointer hover:bg-gray-800 hover:text-white rounded-lg transition" data-page="pages"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><use href="#icon-pages"/></svg>页面模块编辑</a>
<a class="flex items-center gap-3 px-3 py-2.5 text-gray-400 cursor-pointer hover:bg-gray-800 hover:text-white rounded-lg transition" data-page="settings"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><use href="#icon-settings"/></svg>全站配置</a>
<a class="flex items-center gap-3 px-3 py-2.5 text-gray-400 cursor-pointer hover:bg-gray-800 hover:text-white rounded-lg transition" data-page="messages"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><use href="#icon-messages"/></svg>留言管理 <span id="msgBadge" class="ml-auto bg-red-500 text-white text-xs rounded-full px-2 py-0.5 hidden">0</span></a>
<a class="flex items-center gap-3 px-3 py-2.5 text-gray-400 cursor-pointer hover:bg-gray-800 hover:text-white rounded-lg transition" data-page="tools"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><use href="#icon-tools"/></svg>系统工具</a>
</nav>
<div class="p-4 border-t border-gray-800"><a onclick="logout()" class="flex items-center gap-2 text-sm text-gray-400 hover:text-white cursor-pointer"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>退出登录</a></div>
</aside>
<div class="flex-1 flex flex-col min-w-0">
<div class="bg-white border-b border-gray-200 h-16 flex items-center justify-between px-6 sticky top-0 z-10"><span class="text-sm text-gray-400">当前页面：<span id="pageTitle" class="font-semibold text-gray-800">数据仪表盘</span></span><div class="flex items-center gap-3"><span class="text-sm text-gray-600" id="adminInfo"></span><button onclick="logout()" class="text-sm text-red-500 hover:underline">退出</button></div></div>
<div class="p-6" id="pageContent">
<!-- content loaded by JS -->
</div></div></div>
<script>
const TOKEN = localStorage.getItem('fuliya_token');
if(!TOKEN && location.pathname !== '/admin'){ location.href='/admin' }
async function api(url, opt={}){
  opt.headers = opt.headers || {};
  opt.headers['Authorization'] = 'Bearer ' + TOKEN;
  if(opt.body && typeof opt.body === 'object'){ opt.body = JSON.stringify(opt.body); opt.headers['Content-Type']='application/json' }
  const r = await fetch(url, opt); const j = await r.json();
  if(j.code === -1 && j.msg === '未登录'){ localStorage.removeItem('fuliya_token'); location.href='/admin' }
  return j;
}
const pages = {
  dashboard: { title:'数据仪表盘', render: renderDashboard },
  products: { title:'产品管理', render: renderProducts },
  news: { title:'新闻管理', render: renderNews },
  cases: { title:'案例管理', render: renderCases },
  pages: { title:'页面模块编辑', render: renderPages },
  settings: { title:'全站配置', render: renderSettings },
  messages: { title:'留言管理', render: renderMessages },
  tools: { title:'系统工具', render: renderTools }
};
function switchPage(name){
  document.querySelectorAll('#adminNav a').forEach(a => a.classList.remove('active-page'));
  document.querySelector('#adminNav a[data-page="'+name+'"]')?.classList.add('active-page');
  document.getElementById('pageTitle').textContent = pages[name]?.title || name;
  document.getElementById('pageContent').innerHTML = '<div class="text-center py-10 text-gray-400">加载中...</div>';
  pages[name]?.render();
}
document.querySelectorAll('#adminNav a[data-page]').forEach(a => {
  a.addEventListener('click', function(){ switchPage(this.dataset.page); });
});

// === DASHBOARD (align with admin-dashboard.html) ===
async function renderDashboard(){
  const d = await api('/admin-api/dashboard');
  if(!d.data) return;
  const s = d.data;
  document.getElementById('pageContent').innerHTML = [
    // 4 Core Cards with colored left borders (matching prototype)
    '<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-6">',
    '<div class="bg-white rounded-xl p-5 shadow-sm border-l-4 border-[#2ab39f]"><div class="flex items-center justify-between"><div><p class="text-gray-500 text-xs">产品总数</p><p class="text-3xl font-bold text-gray-900 mt-1">'+(s.products||0)+'</p></div><div class="w-12 h-12 bg-[#e8f8f5] rounded-xl flex items-center justify-center"><svg class="w-6 h-6 text-[#2ab39f]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg></div></div><div class="flex gap-2 mt-2"><span class="badge badge-green">'+(s.productOn||0)+' 上架</span><span class="badge badge-gray">'+(s.productOff||0)+' 下架</span></div></div>',
    '<div class="bg-white rounded-xl p-5 shadow-sm border-l-4 border-blue-500"><div class="flex items-center justify-between"><div><p class="text-gray-500 text-xs">新闻总数</p><p class="text-3xl font-bold text-gray-900 mt-1">'+(s.news||0)+'</p></div><div class="w-12 h-12 bg-blue-50 rounded-xl flex items-center justify-center"><svg class="w-6 h-6 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z"/></svg></div></div></div>',
    '<div class="bg-white rounded-xl p-5 shadow-sm border-l-4 border-purple-500"><div class="flex items-center justify-between"><div><p class="text-gray-500 text-xs">案例总数</p><p class="text-3xl font-bold text-gray-900 mt-1">'+(s.cases||0)+'</p></div><div class="w-12 h-12 bg-purple-50 rounded-xl flex items-center justify-center"><svg class="w-6 h-6 text-purple-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/></svg></div></div></div>',
    '<div class="bg-white rounded-xl p-5 shadow-sm border-l-4 border-amber-500"><div class="flex items-center justify-between"><div><p class="text-gray-500 text-xs">未读留言</p><p class="text-3xl font-bold text-gray-900 mt-1 text-red-500">'+(s.unread||0)+'</p></div><div class="w-12 h-12 bg-amber-50 rounded-xl flex items-center justify-center"><svg class="w-6 h-6 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/></svg></div></div><div class="mt-2 text-xs text-red-600">&#9888; 需要立即处理</div></div>',
    '</div>',
    // Visitor Stats (matching prototype)
    '<div class="bg-white rounded-xl p-6 shadow-sm mb-6"><div class="flex items-center justify-between mb-4"><h3 class="font-bold text-gray-900">网站访客统计</h3><div class="flex gap-2 text-xs"><button class="px-3 py-1 bg-[#2ab39f] text-white rounded-full">今日</button><button class="px-3 py-1 text-gray-500 hover:bg-gray-100 rounded-full">本周</button><button class="px-3 py-1 text-gray-500 hover:bg-gray-100 rounded-full">本月</button></div></div><div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-4"><div class="bg-gray-50 rounded-xl p-4 text-center"><p class="text-xs text-gray-500">今日访问</p><p class="text-2xl font-bold text-[#2ab39f] mt-1">--</p><p class="text-xs text-green-600 mt-1">--</p></div><div class="bg-gray-50 rounded-xl p-4 text-center"><p class="text-xs text-gray-500">本月访问</p><p class="text-2xl font-bold text-gray-900 mt-1">--</p><p class="text-xs text-green-600 mt-1">--</p></div><div class="bg-gray-50 rounded-xl p-4 text-center"><p class="text-xs text-gray-500">累计访问</p><p class="text-2xl font-bold text-gray-900 mt-1">--</p><p class="text-xs text-gray-400 mt-1">上线至今</p></div></div><div class="h-48 bg-gradient-to-b from-gray-50 to-gray-100 rounded-xl flex items-center justify-center"><div class="text-center text-gray-400"><svg class="w-8 h-8 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M7 12l3-3 3 3 4-4M8 21l4-4 4 4M3 4h18M4 4h16v12a1 1 0 01-1 1H5a1 1 0 01-1-1V4z"/></svg><p class="text-sm">访客趋势折线图占位区</p></div></div></div>',
    // Chart Placeholders (2 cols: line + pie)
    '<div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">',
    '<div class="bg-white rounded-xl p-6 shadow-sm"><h3 class="font-bold text-gray-900 mb-4">月度数据趋势 (折线图)</h3><div class="h-64 bg-gradient-to-b from-gray-50 to-gray-100 rounded-xl flex items-center justify-center"><div class="text-center text-gray-400"><svg class="w-10 h-10 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M7 12l3-3 3 3 4-4M8 21l4-4 4 4M3 4h18M4 4h16v12a1 1 0 01-1 1H5a1 1 0 01-1-1V4z"/></svg><p class="text-sm">折线图占位区</p></div></div></div>',
    '<div class="bg-white rounded-xl p-6 shadow-sm"><h3 class="font-bold text-gray-900 mb-4">产品分类占比 (饼图)</h3><div class="h-64 bg-gradient-to-b from-gray-50 to-gray-100 rounded-xl flex items-center justify-center"><div class="text-center text-gray-400"><svg class="w-10 h-10 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M11 3.055A9.001 9.001 0 1020.945 13H11V3.055z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M20.488 9H15V3.512A9.025 9.025 0 0120.488 9z"/></svg><p class="text-sm">饼图占位区</p></div></div></div>',
    '</div>',
    // Bar Chart + Recent Messages (matching prototype)
    '<div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">',
    '<div class="bg-white rounded-xl p-6 shadow-sm"><h3 class="font-bold text-gray-900 mb-4">月度发布统计 (柱状图)</h3><div class="h-64 bg-gradient-to-b from-gray-50 to-gray-100 rounded-xl flex items-center justify-center"><div class="text-center text-gray-400"><svg class="w-10 h-10 mx-auto mb-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg><p class="text-sm">柱状图占位区</p></div></div></div>',
    '<div class="bg-white rounded-xl p-6 shadow-sm"><h3 class="font-bold text-gray-900 mb-4">最近留言</h3><div id="recent-messages-list" class="space-y-3">',
    '<div class="flex items-start gap-3 pb-3 border-b border-gray-100"><div class="w-8 h-8 bg-[#e8f8f5] rounded-full flex items-center justify-center text-sm font-bold text-[#2ab39f]">?</div><div class="flex-1 min-w-0"><p class="text-sm font-medium text-gray-900">加载中...</p></div></div>',
    '</div><a href="javascript:switchPage(\'messages\')" class="inline-block mt-4 text-sm text-[#2ab39f] hover:underline">查看全部留言 &rarr;</a></div>',
    '</div>',
    // Quick Actions
    '<div class="bg-white rounded-xl p-6 shadow-sm"><h3 class="font-bold text-gray-900 mb-4">快捷操作</h3><div class="flex flex-wrap gap-3">',
    '<a onclick="switchPage(\'products\')" class="px-5 py-2.5 bg-[#2ab39f] text-white rounded-lg text-sm font-medium cursor-pointer hover:bg-[#1f8f7e] transition">新建产品</a>',
    '<a onclick="switchPage(\'news\')" class="px-5 py-2.5 bg-blue-500 text-white rounded-lg text-sm font-medium cursor-pointer hover:bg-blue-600 transition">发布新闻</a>',
    '<a onclick="switchPage(\'messages\')" class="px-5 py-2.5 bg-amber-500 text-white rounded-lg text-sm font-medium cursor-pointer hover:bg-amber-600 transition">处理留言</a>',
    '<a onclick="switchPage(\'tools\')" class="px-5 py-2.5 bg-gray-600 text-white rounded-lg text-sm font-medium cursor-pointer hover:bg-gray-700 transition">系统工具</a>',
    '</div></div>'
  ].join('');
  // Load recent messages
  try {
    const msgData = await api('/admin-api/messages');
    const msgList = msgData.data?.list || [];
    const recentHtml = msgList.slice(0,4).map(function(m){
      var initial = (m.name || '?').charAt(0);
      var colors = ['bg-[#e8f8f5] text-[#2ab39f]','bg-blue-100 text-blue-500','bg-purple-100 text-purple-500','bg-amber-100 text-amber-500'];
      var ci = Math.abs((m.id||0)) % colors.length;
