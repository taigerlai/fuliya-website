    '<div class="bg-white rounded-xl p-6 shadow-sm hover:shadow-md transition"><div class="w-12 h-12 bg-cyan-100 rounded-xl flex items-center justify-center mb-4"><svg class="w-6 h-6 text-cyan-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg></div><h3 class="font-bold text-gray-900 mb-1">导出日志</h3><p class="text-gray-500 text-xs mb-4">将系统日志导出为 CSV 文件</p><button onclick="toolAction(\'export-log\')" class="border border-gray-200 text-gray-600 px-4 py-2 rounded-lg text-xs hover:bg-gray-50 transition">导出日志</button></div>',
    // Clear Cache
    '<div class="bg-white rounded-xl p-6 shadow-sm hover:shadow-md transition"><div class="w-12 h-12 bg-orange-100 rounded-xl flex items-center justify-center mb-4"><svg class="w-6 h-6 text-orange-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg></div><h3 class="font-bold text-gray-900 mb-1">清除缓存</h3><p class="text-gray-500 text-xs mb-4">清除页面缓存和模板缓存</p><button onclick="toolAction(\'clear-cache\')" class="bg-orange-500 text-white px-4 py-2 rounded-lg text-xs font-medium hover:bg-orange-600 transition">立即清除</button></div>',
