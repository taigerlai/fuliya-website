function insertBlock(type){
  var names = {image:'单图区块',grid:'多图网格区块',heading:'标题区块',text:'正文段落区块','image-text':'左右图文区块'};
  var c = document.getElementById('blocks-container');
  var d = document.createElement('div');
  d.className = 'block-item';
  d.innerHTML = '<div class="block-handle">⠿</div><div class="flex items-center justify-between mb-2"><span class="text-sm font-medium text-gray-700">'+names[type]+'</span><button class="text-gray-400 hover:text-red-500 text-xs" onclick="this.parentElement.parentElement.remove()">删除</button></div><div class="text-sm text-gray-400">（<%= lang==='zh' ? '点击编辑内容' : 'Click to edit' %>）</div>';
  c.appendChild(d);
}

// 模态框
function showModal(html){
  document.getElementById('mbd').innerHTML = html;
  document.getElementById('modal').style.display = 'flex';
}
function cm(){ document.getElementById('modal').style.display = 'none'; }

// =====================================
// 表单提交 — 收集全部 7 个 Tab 的数据
// =====================================
function collectFormData(){
  var d={};

  // Tab1: 基础信息
  // title_zh - first input with maxlength=200
  d.title_zh = document.querySelector('#c-basic input[maxlength="200"]')?.value||'';
  // title_en - use title_zh as fallback (no separate en field in UI yet)
  d.title_en = d.title_zh;
  // category_id
  var catSelect = document.querySelector('#c-basic select');
  d.category_id = catSelect ? parseInt(catSelect.value)||0 : 0;
  // brand
  d.brand = document.querySelector('#c-basic input[maxlength="200"]')?.closest('.col-span-2')?.nextElementSibling?.querySelector('input')?.value || 'FULIYA';
  if(!d.brand || d.brand==='FULIYA'){
    // find by trying all inputs
    var allInputs=document.querySelectorAll('#c-basic input');
    for(var i=0;i<allInputs.length;i++){
      if(allInputs[i].value && allInputs[i].value!=='FULIYA' && !allInputs[i].maxLength){
        d.brand=allInputs[i].value;
        break;
      }
    }
  }
  d.short_name = document.querySelector('#c-basic input[maxlength="20"]')?.value||'';
  d.summary = document.querySelector('#c-basic textarea')?.value||'';

  // Tab2: 规格参数
  var specs=[];
  document.querySelectorAll('#specs-body tr').forEach(function(tr){
    var inputs=tr.querySelectorAll('input');
    if(inputs.length>=2) specs.push({name:inputs[0].value,value:inputs[1].value});
  });
  d.specs=JSON.stringify(specs);

  // Tab3: 图片与详情 - 收集主图 + 区块
  var images=[];
  // collect from the upload area
  d.main_image = '';

  // Blocks
  var blocks=[];
  var blockItems=document.querySelectorAll('#blocks-container .block-item');
  blockItems.forEach(function(item){
    var type=item.dataset.blockType||'text';
    blocks.push({type:type});
  });
  d.blocks=JSON.stringify(blocks);

  // Tab4: 卖点与标签
  var highlights=[];
  document.querySelectorAll('#highlights-container .block-item').forEach(function(item){
    var inputs=item.querySelectorAll('input');
    if(inputs.length>=2) highlights.push({title:inputs[0].value,text:inputs[1].value});
  });
  d.highlights=JSON.stringify(highlights);

  // Tags
  var tagsInput = document.querySelector('#c-highlights input[placeholder*=","]') ||
                  document.querySelector('#c-highlights input[type="text"]:last-of-type');
  if(tagsInput) d.tags=tagsInput.value;

  // Tab5: SEO / URL 别名
  // Get slug from the URL alias field (the input with the placeholder containing hyphens)
  d.slug = '';
  document.querySelectorAll('#c-seo input').forEach(function(el){
    if(el.placeholder && el.placeholder.indexOf('-')>=0 && el.placeholder.indexOf('custom')>=0){
      d.slug = el.value;
    }
  });
  // SEO fields
  var seoLabels=['seo_title','seo_desc','seo_keywords','canonical','seo_indexed','auto_alt','auto_structured'];
  var seoInputs=document.querySelectorAll('#c-seo input, #c-seo textarea');
  seoInputs.forEach(function(el){
    if(el.type==='checkbox'){
      // Determine which field this is
      var label=el.closest('label');
      if(label && label.textContent.indexOf('收录')>=0) d.seo_indexed=el.checked?1:0;
      else if(label && label.textContent.indexOf('ALT')>=0) d.auto_alt=el.checked?1:0;
      else if(label && label.textContent.indexOf('结构化')>=0) d.auto_structured=el.checked?1:0;
    }
  });

  // Tab6: 关联推荐
  d.recommend_title = document.querySelector('#c-related input')?.value||'Product recommendation';
  var sel=document.querySelector('#c-related select');
  if(sel){
    var ids=[];
    for(var i=0;i<sel.options.length;i++) if(sel.options[i].selected) ids.push(parseInt(sel.options[i].value));
    d.recommends=JSON.stringify(ids);
  }

  // Tab7: FAQ
  var faqs=[];
  document.querySelectorAll('#faq-container .block-item').forEach(function(item){
    var inputs=item.querySelectorAll('input');
    if(inputs.length>=2) faqs.push({q:inputs[0].value,a:inputs[1].value});
  });
  d.faqs=JSON.stringify(faqs);
  d.faq_show = document.querySelector('#c-faq input[type="checkbox"]')?.checked?1:0;

  // Backward compat fields
  d.content_zh = d.summary || '';
  d.content_en = d.summary || '';
  d.thumbnail = d.main_image || '';
  d.images = '[]';

  // Status from radio (convert to numeric: 1=上架, 0=下架/草稿)
  var statusRadio=document.querySelector('input[name="status"]:checked');
  var st = statusRadio ? statusRadio.value : 'draft';
  d.status = st === 'published' ? 1 : 0;

  return d;
}

function saveProduct(status){
  var d=collectFormData();
  d.status=status||d.status;
  var isNew = !<%= product?.id ? 'true' : 'false' %>;
  var url = isNew ? '/admin-api/products' : '/admin-api/products/<%= product?.id || '' %>';
  var method = isNew ? 'POST' : 'PUT';

  api(url, {method:method, body:d}).then(function(j){
    if(j.code===0){
      alert(status==='published' ? '<%= lang==='zh' ? '产品已发布！' : 'Published!' %>' : '<%= lang==='zh' ? '草稿已保存' : 'Draft saved' %>');
      location.href='/admin/products';
    } else {
      alert(j.msg || '<%= lang==='zh' ? '保存失败' : 'Save failed' %>');
    }
  });
}

function saveDraft(){ saveProduct('draft'); }
function publish(){ saveProduct('published'); }

// API helper (using localStorage token)
function api(url,opts){
  if(!opts)opts={};
  if(!opts.headers)opts.headers={};
  opts.headers['Authorization']='Bearer '+localStorage.getItem('admin_token');
  if(opts.body && typeof opts.body==='object'){
    opts.body=JSON.stringify(opts.body);
    opts.headers['Content-Type']='application/json';
  }
  return fetch(url,opts).then(function(r){return r.json();}).catch(function(e){return{code:-1,msg:e.message};});
}
</script>
</body></html>
