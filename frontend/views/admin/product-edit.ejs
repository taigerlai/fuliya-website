  showModal('<h3 class="text-lg font-bold mb-4"><%= lang==='zh' ? '选择区块类型' : 'Select Block Type' %></h3><div class="grid grid-cols-2 gap-3"><button class="p-4 border rounded-lg hover:border-[#2ab39f] text-left" onclick="insertBlock(\'image\');cm()">📷 单图</button><button class="p-4 border rounded-lg hover:border-[#2ab39f] text-left" onclick="insertBlock(\'grid\');cm()">🔲 多图网格</button><button class="p-4 border rounded-lg hover:border-[#2ab39f] text-left" onclick="insertBlock(\'heading\');cm()">📝 标题</button><button class="p-4 border rounded-lg hover:border-[#2ab39f] text-left" onclick="insertBlock(\'text\');cm()">📄 正文段落</button><button class="p-4 border rounded-lg hover:border-[#2ab39f] text-left" onclick="insertBlock(\'image-text\');cm()">🖼 左右图文</button></div>');
