<%- include('../partials/header', { config, lang, path: '/news' }) %>
<div class="banner-placeholder banner-placeholder-sm"><div class="relative z-10 text-center px-4"><h1 class="text-3xl md:text-4xl font-bold text-white"><%= lang==='zh' ? '新闻中心' : 'News' %></h1></div></div>
<div class="max-w-6xl mx-auto px-4 py-16">
  <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
    <% if (news && news.length) { news.forEach(n => { %>
    <div class="bg-white rounded-xl border border-gray-200 overflow-hidden"><div class="h-44 bg-gradient-to-br from-gray-100 to-gray-200"></div><div class="p-5"><p class="text-xs text-gray-400"><%= new Date(n.create_time).toLocaleDateString() %></p><h3 class="font-semibold mt-1"><%= lang==='zh' ? n.title_zh : n.title_en %></h3></div></div>
    <% }) } else { %><p class="col-span-3 text-center text-gray-400 py-10"><%= lang==='zh' ? '暂无新闻' : 'No news yet' %></p><% } %>
  </div>
</div>
<%- include('../partials/footer', { config, lang }) %>
