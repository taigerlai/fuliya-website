<%- include('../partials/head', { config, lang }) %>
<%- include('../partials/header', { config, lang, path: '/strength' }) %>
<div class="banner-placeholder banner-placeholder-sm"><div class="relative z-10 text-center px-4"><h1 class="text-3xl md:text-4xl font-bold text-white"><%= lang==='zh' ? '企业实力' : 'Our Strength' %></h1></div></div>
<div class="max-w-6xl mx-auto px-4 py-16 space-y-20">
  <section><h2 class="section-title"><%= lang==='zh' ? '生产基地' : 'Manufacturing Base' %></h2><div class="h-72 rounded-2xl bg-gradient-to-br from-gray-100 to-gray-200 flex items-center justify-center text-gray-400"><%= lang==='zh' ? '生产基地航拍图' : 'Factory Aerial View' %></div></section>
  <section><h2 class="section-title"><%= lang==='zh' ? '资质证书' : 'Certifications' %></h2><div class="grid grid-cols-2 md:grid-cols-4 gap-4"><div class="h-40 rounded-xl bg-gray-100 flex items-center justify-center text-gray-400">ISO 9001</div><div class="h-40 rounded-xl bg-gray-100 flex items-center justify-center text-gray-400">BSCI</div><div class="h-40 rounded-xl bg-gray-100 flex items-center justify-center text-gray-400">SGS</div><div class="h-40 rounded-xl bg-gray-100 flex items-center justify-center text-gray-400">Intertek</div></div></section>
  <section><h2 class="section-title"><%= lang==='zh' ? '生产能力' : 'Capacity' %></h2><div class="grid grid-cols-1 md:grid-cols-3 gap-6"><div class="text-center p-8 rounded-xl bg-[#e6f7f4]"><div class="text-4xl font-bold text-[#2ab39f]">500万+</div><div class="text-gray-600 mt-2"><%= lang==='zh' ? '年产量' : 'Annual Output' %></div></div><div class="text-center p-8 rounded-xl bg-[#e6f7f4]"><div class="text-4xl font-bold text-[#2ab39f]">8000㎡</div><div class="text-gray-600 mt-2"><%= lang==='zh' ? '厂房面积' : 'Factory Area' %></div></div><div class="text-center p-8 rounded-xl bg-[#e6f7f4]"><div class="text-4xl font-bold text-[#2ab39f]">200+</div><div class="text-gray-600 mt-2"><%= lang==='zh' ? '熟练技工' : 'Skilled Workers' %></div></div></div></section>
</div>
<%- include('../partials/footer', { config, lang }) %>
