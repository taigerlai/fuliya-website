<%- include('../partials/head', { config, lang }) %>
<%- include('../partials/header', { config, lang, path: '/contact' }) %>
<div class="banner-placeholder banner-placeholder-sm"><div class="relative z-10 text-center px-4"><h1 class="text-3xl md:text-4xl font-bold text-white"><%= lang==='zh' ? '联系我们' : 'Contact Us' %></h1></div></div>
<div class="max-w-6xl mx-auto px-4 py-16">
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
    <div><h2 class="text-xl font-bold mb-6"><%= lang==='zh' ? '联系方式' : 'Contact Info' %></h2><div class="space-y-5">
      <div class="flex items-start gap-4"><div class="w-10 h-10 rounded-xl bg-[#e6f7f4] flex items-center justify-center flex-shrink-0"><svg class="w-5 h-5 text-[#2ab39f]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg></div><div><p class="font-medium"><%= lang==='zh' ? '公司地址' : 'Address' %></p><p class="text-gray-500 text-sm"><%= config?.company_address || (lang==='zh' ? '广州市白云区某某路 88 号' : 'Guangzhou, China') %></p></div></div>
      <div class="flex items-start gap-4"><div class="w-10 h-10 rounded-xl bg-[#e6f7f4] flex items-center justify-center flex-shrink-0"><svg class="w-5 h-5 text-[#2ab39f]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg></div><div><p class="font-medium"><%= lang==='zh' ? '联系电话' : 'Phone' %></p><p class="text-gray-500 text-sm"><%= config?.phone || '+86-20-12345678' %></p></div></div>
      <div class="flex items-start gap-4"><div class="w-10 h-10 rounded-xl bg-[#e6f7f4] flex items-center justify-center flex-shrink-0"><svg class="w-5 h-5 text-[#2ab39f]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg></div><div><p class="font-medium"><%= lang==='zh' ? '邮箱' : 'Email' %></p><p class="text-gray-500 text-sm"><%= config?.email || 'info@fuliya.com' %></p></div></div>
    </div></div>
    <div><h2 class="text-xl font-bold mb-6"><%= lang==='zh' ? '在线留言' : 'Send Message' %></h2>
    <form class="space-y-4" id="contactForm"><div class="grid grid-cols-1 sm:grid-cols-2 gap-4"><input type="text" name="name" placeholder="<%= lang==='zh' ? '您的姓名 *' : 'Your Name *' %>" class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:border-[#2ab39f] outline-none"><input type="text" name="company" placeholder="<%= lang==='zh' ? '公司名称' : 'Company' %>" class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:border-[#2ab39f] outline-none"></div>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4"><input type="email" name="email" placeholder="<%= lang==='zh' ? '邮箱 *' : 'Email *' %>" class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:border-[#2ab39f] outline-none"><input type="tel" name="phone" placeholder="<%= lang==='zh' ? '手机号' : 'Phone' %>" class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:border-[#2ab39f] outline-none"></div>
    <textarea name="demand" rows="4" placeholder="<%= lang==='zh' ? '请输入您的需求 *' : 'Your Requirements *' %>" class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:border-[#2ab39f] outline-none resize-none"></textarea>
    <button type="submit" class="w-full bg-[#2ab39f] text-white py-3.5 rounded-lg font-semibold hover:bg-[#1f8e7d] transition"><%= lang==='zh' ? '提交留言' : 'Submit' %></button>
    </form></div>
  </div>
</div>
<script>document.getElementById('contactForm')?.addEventListener('submit', async function(e){e.preventDefault();const f=new FormData(this);const d=Object.fromEntries(f);const r=await fetch('/api/messages',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify(d)});const j=await r.json();alert(j.msg);if(j.code===0)this.reset();});</script>
<%- include('../partials/footer', { config, lang }) %>
